generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" 
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  email        String   @unique
  nomeCompleto String   
  password     String
  refreshToken String?
  imagens      Imagens[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  idade        Int
  curso        Int
} 

model Imagens {
  id           Int      @id @default(autoincrement())
  authorId     Int  
  author       User @relation(fields: [authorId], references: [id])
  nomeCompleto        String   @unique
  password     String
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  idade        Int
  curso        Int
} 